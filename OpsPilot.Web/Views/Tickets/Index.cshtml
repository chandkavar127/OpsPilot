@model List<OpsPilot.Domain.Entities.Ticket>
@{
    ViewData["Title"] = "IT Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>IT Support Tickets</h3>
    <a asp-action="Create" class="btn btn-primary">Raise Ticket</a>
</div>

<div class="card card-stats p-3">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Subject</th>
                <th>Category</th>
                <th>Priority</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var ticket in Model)
        {
            <tr>
                <td>@ticket.Id</td>
                <td>@ticket.Subject</td>
                <td>@ticket.Category</td>
                <td>@ticket.Priority</td>
                <td>@ticket.Status</td>
            </tr>
        }
        </tbody>
    </table>
</div>
